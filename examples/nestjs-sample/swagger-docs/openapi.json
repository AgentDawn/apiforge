{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/pets": {
      "get": {
        "operationId": "PetController_findAll",
        "summary": "펫 목록 조회",
        "description": "등록된 모든 펫의 목록을 조회합니다.",
        "parameters": [
          {
            "name": "species",
            "required": false,
            "in": "query",
            "description": "종류로 필터링",
            "schema": {
              "enum": [
                "dog",
                "cat",
                "bird",
                "fish"
              ],
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "최대 결과 수",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "펫 목록",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetListResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "pets"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      },
      "post": {
        "operationId": "PetController_create",
        "summary": "펫 등록",
        "description": "새로운 펫을 등록합니다.",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePetDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "생성된 펫 정보",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청"
          }
        },
        "tags": [
          "pets"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      }
    },
    "/api/v1/pets/{id}": {
      "get": {
        "operationId": "PetController_findOne",
        "summary": "펫 상세 조회",
        "description": "특정 펫의 상세 정보를 조회합니다.",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "펫 ID",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "펫 상세 정보",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "펫을 찾을 수 없음"
          }
        },
        "tags": [
          "pets"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      },
      "put": {
        "operationId": "PetController_update",
        "summary": "펫 정보 수정",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "펫 ID",
            "schema": {
              "type": "number"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePetDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "pets"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      },
      "delete": {
        "operationId": "PetController_remove",
        "summary": "펫 삭제",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "펫 ID",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "삭제 완료"
          },
          "404": {
            "description": "펫을 찾을 수 없음"
          }
        },
        "tags": [
          "pets"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      }
    },
    "/api/v1/pets/{id}/avatar": {
      "post": {
        "operationId": "PetController_uploadAvatar",
        "summary": "펫 아바타 업로드",
        "description": "펫의 프로필 이미지를 업로드합니다.",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "펫 ID",
            "schema": {
              "type": "number"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "이미지 파일"
                  },
                  "description": {
                    "type": "string",
                    "description": "이미지 설명"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "업로드 완료",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "pets"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      }
    },
    "/api/v1/users/register": {
      "post": {
        "operationId": "UserController_register",
        "summary": "회원가입",
