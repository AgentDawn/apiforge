              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          },
          "409": {
            "description": "이미 존재하는 이메일"
          }
        },
        "tags": [
          "users"
        ]
      }
    },
    "/api/v1/users/login": {
      "post": {
        "operationId": "UserController_login",
        "summary": "로그인 (Form URL-Encoded)",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT 토큰",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "인증 실패"
          }
        },
        "tags": [
          "users"
        ]
      }
    },
    "/api/v1/users/register-multi": {
      "post": {
        "operationId": "UserController_registerMulti",
        "summary": "회원가입 (JSON + Form)",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDto"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "생성된 사용자 정보 (multiple content types)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "users"
        ]
      }
    },
    "/api/v1/users/me": {
      "get": {
        "operationId": "UserController_getMe",
        "summary": "내 정보 조회",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "users"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "operationId": "UserController_findOne",
        "summary": "사용자 조회",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "사용자 ID",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "사용자를 찾을 수 없음"
          }
        },
        "tags": [
          "users"
        ],
        "security": [
          {
            "JWT": []
          }
        ]
      }
    },
    "/petstore.v1.PetService/GetPet": {
      "post": {
        "operationId": "GrpcController_httpGetPet",
