  "info": {
    "title": "Petstore API",
    "description": "A sample pet store API for APIForge testing",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local"
    },
    {
      "url": "https://api.petstore.example.com",
      "description": "Production"
    }
  ],
  "components": {
    "securitySchemes": {
      "JWT": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "PetResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "펫 ID",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "펫 이름"
          },
          "species": {
            "type": "string",
            "description": "펫 종류"
          },
          "age": {
            "type": "number",
            "description": "펫 나이"
          },
          "createdAt": {
            "type": "string",
            "description": "등록일"
          }
        },
        "required": [
          "id",
          "name",
          "species",
          "createdAt"
        ]
      },
      "PetListResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PetResponseDto"
            }
          },
          "total": {
            "type": "number",
            "description": "전체 개수"
          }
        },
        "required": [
          "items",
          "total"
        ]
      },
      "CreatePetDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "펫 이름",
            "example": "Buddy"
          },
          "species": {
            "type": "string",
            "description": "펫 종류",
            "enum": [
              "dog",
              "cat",
              "bird",
              "fish"
            ]
          },
          "age": {
            "type": "number",
            "description": "펫 나이",
            "example": 3
          },
          "tags": {
            "description": "태그 목록",
            "example": [
              "friendly",
              "trained"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "species"
        ]
      },
      "UpdatePetDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "펫 이름"
          },
          "species": {
            "type": "string",
            "description": "펫 종류",
            "enum": [
              "dog",
              "cat",
              "bird",
              "fish"
            ]
          },
          "age": {
            "type": "number",
            "description": "펫 나이"
          }
        }
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "이메일",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "description": "비밀번호",
            "minLength": 8
          },
          "displayName": {
            "type": "string",
            "description": "사용자 이름",
            "example": "John Doe"
          }
        },
        "required": [
          "email",
          "password",
          "displayName"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "사용자 ID"
          },
          "email": {
            "type": "string",
            "description": "이메일"
          },
          "displayName": {
            "type": "string",
            "description": "사용자 이름"
          },
          "avatarUrl": {
            "type": "string",
            "description": "프로필 이미지 URL"
          },
          "createdAt": {
            "type": "string",
            "description": "가입일"
          }
        },
        "required": [
          "id",
          "email",
          "displayName",
          "createdAt"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "이메일"
          },
          "password": {
            "type": "string",
            "description": "비밀번호"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "TokenResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT 액세스 토큰"
          },
          "expiresIn": {
            "type": "number",
            "description": "토큰 만료 시간 (초)"
          }
        },
        "required": [
          "accessToken",
          "expiresIn"
        ]
      }
    }
  }
}